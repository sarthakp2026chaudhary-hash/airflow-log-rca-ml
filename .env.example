# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Used in Phase 4 (LLM-based RCA summarisation).
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the default model used for RCA summaries.
# Defaults to claude-sonnet-4-6 in code.
# ANTHROPIC_MODEL=claude-sonnet-4-6
